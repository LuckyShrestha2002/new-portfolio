rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow read access to anyone
    // Only allow write access to authenticated user with your admin email
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "YOUR_ADMIN_EMAIL@domain.com"; // Replace with your actual admin email
    }
  }
}
